# --- PROVEEDORES DE IA (LLAVES) ---

# Google Gemini
GEMINI_API_KEY="TU_GEMINI_API_KEY"

# OpenAI
OPENAI_API_KEY="TU_OPENAI_API_KEY"

# Groq
GROQ_API_KEY="TU_GROQ_API_KEY"

# DeepSeek
DEEPSEEK_API_KEY="TU_DEEPSEEK_API_KEY"

# OpenRouter (Claude, GPT-4, Llama via Web)
OPENROUTER_API_KEY="TU_OPENROUTER_API_KEY"

# Mistral AI
MISTRAL_API_KEY="TU_MISTRAL_API_KEY"

# --- CONFIGURACIÓN DEL SISTEMA ---

# Puerto del Servidor Proxy (BFF)
PORT=8080
BACKEND_HOST=0.0.0.0
VITE_FRONTEND_PORT=3000
VITE_API_HOST=localhost
PROJECT_FALLBACK_NAME="Unnamed Project"
CONTEXT_DIRECTORY_NAME="contexto"

# URL de desarrollo
VITE_API_URL="http://localhost:8080"

# Proveedor y modelos por defecto en frontend
VITE_DEFAULT_AI_PROVIDER="groq"
VITE_DEFAULT_GEMINI_MODEL="gemini-1.5-flash"
VITE_DEFAULT_OPENAI_MODEL="gpt-4o"
VITE_DEFAULT_GROQ_MODEL="llama-3.3-70b-versatile"
VITE_DEFAULT_DEEPSEEK_MODEL="deepseek-chat"
VITE_DEFAULT_OPENROUTER_MODEL="anthropic/claude-3.5-sonnet"
VITE_DEFAULT_MISTRAL_MODEL="mistral-large-latest"
VITE_DEFAULT_OLLAMA_MODEL="llama3"
VITE_DEFAULT_FALLBACK_MODEL="gpt-4o-mini"
VITE_PROVIDER_KEY_PLACEHOLDER="sk-..."
VITE_CUSTOM_PROVIDER_URL_PLACEHOLDER="https://api.your-provider.com/v1"

# Modelos por defecto en backend
GEMINI_MODEL="gemini-1.5-flash"
OPENAI_MODEL="gpt-4o"
GROQ_MODEL="llama-3.3-70b-versatile"
DEEPSEEK_MODEL="deepseek-chat"
OPENROUTER_MODEL="anthropic/claude-3.5-sonnet"
MISTRAL_MODEL="mistral-large-latest"
OLLAMA_MODEL="llama3"
CUSTOM_MODEL="gpt-4o-mini"

# Endpoints configurables por proveedor
OPENAI_BASE_URL="https://api.openai.com/v1"
GROQ_BASE_URL="https://api.groq.com/openai/v1"
DEEPSEEK_BASE_URL="https://api.deepseek.com"
OPENROUTER_BASE_URL="https://openrouter.ai/api/v1"
MISTRAL_BASE_URL="https://api.mistral.ai/v1"
OLLAMA_BASE_URL="http://localhost:11434/v1"

# NOTA PARA OLLAMA: No requiere llave. 
# El sistema se conecta automáticamente a http://localhost:11434/v1
